# ── SLS（阿里云日志服务）──────────────────────────────
SLS_ENDPOINT=
SLS_PROJECT=
SLS_LOGSTORE=gateway
SLS_TOPIC=auth
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# ── 生产数据库（只读账号）────────────────────────────
PROD_DB_HOST=localhost
PROD_DB_PORT=3306
PROD_DB_NAME=tokenplan_test
PROD_DB_USERNAME=root
PROD_DB_PASSWORD=

# ── LLM 提供商（Agent 层使用，MCP 层不需要）─────────
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# ── 中转站（OpenAI 兼容接口，支持 Anthropic/OpenAI 协议）─
# 填写后 AGENT_DEFAULT_MODEL 可使用中转站模型名，如 anthropic/claude-opus-4-7
RELAY_API_KEY=
RELAY_BASE_URL=https://aiberm.com/v1

# ── Agent 运行配置（Phase 1+）────────────────────────
# 默认使用的模型（claude-opus-4-6 / gpt-4.1 等）
AGENT_DEFAULT_MODEL=claude-opus-4-6
# SQLite 持久化路径，留空则使用 ./data/agent.db
AGENT_DB_PATH=

# ── RAG 配置（Phase 3）───────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_SIMILARITY_THRESHOLD=0.42
RAG_TOP_K=3
RAG_DB_PATH=
RAG_STORE_BACKEND=sqlite
